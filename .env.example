# Vercel Postgres
# These are automatically configured when you add Postgres storage in Vercel
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Resend - Email Service
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Admin Authentication
# Used for /admin/waitlist access
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here
