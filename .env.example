# Database (required)
# Example: postgresql://user:password@localhost:5432/saheeb
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/saheeb

# Optional origin override for CSRF (comma-separated)
# If omitted, defaults include saheeb.com + localhost development URLs.
# ALLOWED_ORIGINS=https://saheeb.com,https://www.saheeb.com

# Resend - Email Service (optional)
# If empty, email notifications are skipped while submissions still persist to DB.
RESEND_API_KEY=re_xxxxxxxxxxxx

# Google Analytics (optional, production public hosts only)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-HGJLGVH1GP

# Meta Pixel (optional, production public hosts only)
NEXT_PUBLIC_META_PIXEL_ID=1822416752477116

# Microsoft Clarity (optional, only bootstrapped on Saheeb Drive after consent)
NEXT_PUBLIC_CLARITY_PROJECT_ID=
CLARITY_DATA_EXPORT_API_TOKEN=

# Meta Conversions API (optional, server-side lead events)
META_CAPI_ACCESS_TOKEN=
# META_CAPI_TEST_EVENT_CODE=

# Admin Authentication (required)
# Used for /api/admin/waitlist and /admin/waitlist dashboard access
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-unique-password
